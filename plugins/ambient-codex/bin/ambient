        MAX_COMPLETE_ATTEMPTS=MAX_COMPLETE_ATTEMPTS,
        MIN_OUTPUT_TOKENS=MIN_OUTPUT_TOKENS, NetworkError=NetworkError,
        RequestSpec=RequestSpec, StallError=StallError, _as_pos_int=_as_pos_int,
        _budget_escalation_limit=_budget_escalation_limit,
        _effective_cpt=_effective_cpt, _fallback_enabled=_fallback_enabled,
        _reasoning_str=_reasoning_str, _session_or=_session_or,
