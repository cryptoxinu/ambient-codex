# ── ambient config: one clean home for user settings (no env editing) ──────
# Every write goes through save_config_values (atomic, 0600, merge-preserving);
# every read uses the SAME env-or-config resolvers the rest of the CLI already
# uses, so a `config set` takes effect with NO reader change. set/unset may touch
# ONLY the CONFIG_SETTINGS whitelist below — never the model/mode/curation/
# endpoint/key keys (those keep their own commands). The API key is never a config
# value: it can only be set via `ambient-codex setup` (hidden input, user's terminal).
def _config_fmt_num(x):
    """5.0 → '5', 1.5 → '1.5' — clean display of an often-integral float."""
    return _settings_commands.format_number(x)


def _config_norm_bool(raw):
    """on/off/true/false/1/0/yes/no (any case) → 'on'/'off', else ValueError.
    Stored as the literal on/off, which every boolean reader reads identically:
    PROGRESS/FLEET treat off/0/false/no as off (else on); FALLBACK treats
    1/on/true as on, and 'off' is outside that set → off."""
    return _settings_commands.normalize_bool(raw)


def _config_norm_price(raw):
    """A frontier reference price ('in/out' pair like 3/15, or one blended figure)."""
    return _settings_commands.normalize_price(raw, parse_reference_price)


# Whitelist: friendly name → (env key, validator/normalizer, default, current
# reader, value-syntax hint). This tuple is the ONLY set of keys set/unset can
# write — the guarantee that a settings change can never clobber another command's
# config. current() reads the SAME resolver the CLI uses at runtime (zero network).
CONFIG_SETTINGS = (
    {"name": "streaming", "env": "AMBIENT_PROGRESS", "default": "on", "how": "on|off",
     "validate": _config_norm_bool,
     "current": lambda conf: "on" if _progress_from_env_or_conf(conf) else "off"},
    {"name": "fallback", "env": "AMBIENT_FALLBACK", "default": "off", "how": "on|off",
     "validate": _config_norm_bool,
     "current": lambda conf: "on" if str(
         os.environ.get("AMBIENT_FALLBACK") or conf.get("AMBIENT_FALLBACK") or ""
     ).strip().lower() in ("1", "on", "true") else "off"},
    {"name": "reference-price", "env": "AMBIENT_REFERENCE_PRICE", "default": "3/15",
     "how": "<in/out>", "validate": _config_norm_price,
     "current": lambda conf: "/".join(
         _config_fmt_num(x) for x in resolve_reference_price(conf))},
    {"name": "savings", "env": "AMBIENT_SAVINGS", "default": "off", "how": "on|off",
     "validate": _config_norm_bool,
     "current": lambda conf: "on" if _savings_enabled(conf) else "off"},
)
_CONFIG_BY_NAME = {s["name"]: s for s in CONFIG_SETTINGS}


def _config_names():
    return _settings_commands.config_names(CONFIG_SETTINGS)


def _config_env_shadow_note(env):
    """Warn (once, on stderr) when an exported env var will shadow the file write —
    so a user who sets a value but sees no change understands the precedence."""
    return _settings_commands.env_shadow_note(env, os.environ)


def _config_redact(text):
    """Echo an unknown setting name back ONLY if it is a short, clean slug (a
    plausible typo like 'streming'). Anything else — a mistyped key, a value with
    spaces/unicode, a vendor-format secret, a long opaque token — is replaced with a
    placeholder, so nothing secret-shaped can ever reach stderr (Codex 2026-07-08:
    a whitelist of safe SHAPE beats a blocklist of secret shapes)."""
    return _settings_commands.redact_unknown(text, SECRET_PATTERNS)


def _config_curation_summary(conf):
    """Zero-network: whether any curation is configured (no catalog fetch)."""
    return _settings_commands.curation_summary(conf, os.environ)


def _config_print_status():
    """The `ambient-codex config` table. Two aligned blocks: settings OWNED by other
    commands (pointers, not duplicated), then the config-owned knobs. Purely local
    reads — the API key VALUE is never printed, only its backend."""
    return _settings_commands.print_config_status(_settings_dependencies())


def _settings_dependencies():
    return _settings_commands.ConfigDependencies(
        settings=CONFIG_SETTINGS,
        save_config=save_config_values,
        read_config=read_config_file,
        resolve_key=resolve_key_and_backend,
        resolve_model=resolve_model,
        usage_error=usage_exit,
        launcher_name=LAUNCHER_NAME,
        secret_patterns=SECRET_PATTERNS,
        environ=os.environ,
    )


def cmd_config(args):
    """User settings in one place — no env vars, no hand-editing the config file.
    Keyless (config-only, no network). `ambient-codex config` shows everything; `set`/
    `unset` change one whitelisted knob."""
    return _settings_commands.run_config(args, _settings_dependencies())


# ── ambient control: Codex-native settings panel and safe state router ─────
# Printed for the user to copy-paste. They MUST name this install's launcher: a bare
# `ambient` on PATH may belong to a different Ambient install, and pasting
# `ambient-codex control mode on` would flip that install's mode instead of this one's.
CONTROL_ACTIONS = tuple(
    f"{LAUNCHER_NAME} {suffix}".rstrip()
    for suffix in (
        "control",
        "control mode on",
        "control mode takeover",
        "control mode off",
        "control model MODEL",
        "control model MODEL --chat",
        "control model MODEL --code",
        "models --json",
        "setup",
        "setup --force",
        "setup --remove",
        "control setting streaming on|off",
        "control setting fallback on|off",
        "control setting savings on|off",
        "ask PROMPT",
        "audit --staged --json",
        "audit FILE... --json",
        "audit --repo DIR --json",
        "code TASK --json",
        "build TASK --dir DIR --json",
        "doctor",
        "usage --json",
        "agent",
    )
)

CONTROL_SETTING_NAMES = ("streaming", "fallback", "savings")

CONTROL_MODE_OPTIONS = (
    ("off", "Off", "Codex works normally; Ambient runs only when you ask."),
    ("on", "Delegate", "Codex plans and reviews; Ambient handles audits, builds, and large asks."),
    ("takeover", "Ambient session", "Ambient is the direct chat and work engine for this session."),
)

CONTROL_WORKFLOWS = (
