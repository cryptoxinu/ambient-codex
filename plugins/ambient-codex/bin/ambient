class _StreamRedactor:
    """Streaming-safe redaction (M43). Per-piece redact() misses an API key or
    escape sequence that STRADDLES a provider chunk boundary — neither piece
    holds the contiguous secret. Two concerns are handled SEPARATELY so neither
    can defeat the other (an escape injected inside a boundary-split key was the
    subtle failure of the naive rolling-tail):

    1. Escapes: peel any INCOMPLETE trailing escape (an ESC not yet a full
       sequence) back into the raw buffer; sanitize the rest into an
       escape-free `_san` buffer.
    2. Key: key-redact `_san` and emit all but its last (len(key)-1) chars — a
       still-in-flight key prefix is at most that long and stays held until it
       either completes (→ redacted placeholder) or is flushed.

    `_san` holds only the UN-emitted tail: each _emit() drops the committed,
    key-safe prefix, so redact() runs on a bounded window (~keep + delta) rather
    than re-scanning the whole growing stream — O(total) instead of O(total^2)
    over a long streamed answer (a hostile endpoint can't amplify that with many
    tiny deltas)."""

    def __init__(self, api_key):
        self._key = api_key if (api_key and len(api_key) >= 8) else ""
        self._keep = max(len(self._key) - 1, 0)
        self._raw = ""        # not-yet-escape-stable input
        self._san = ""        # sanitized (escape-free) UN-emitted tail

    @staticmethod
    def _stable_len(s):
        """Index up to which `s` has no trailing INCOMPLETE escape sequence.
        Conservative for streaming: an OSC/DCS/PM/APC without its string
        terminator (BEL or ST=ESC\\) may still be arriving, so it is HELD — even
        though ANSI_RE would match the unterminated form in a whole-string pass.
        A CSI is stable only once it has a final byte (@-~)."""
        i = s.rfind("\x1b")                   # DCS/OSC content has no ESC, so the
        if i == -1:                           # last ESC starts the only open escape
            return len(s)
        tail = s[i:]
        if len(tail) == 1:
            return i                          # lone ESC — incomplete
        c = tail[1]
        if c == "[":                          # CSI: complete once it has a final byte
            return len(s) if re.match(r"\x1b\[[0-?]*[ -/]*[@-~]", tail) else i
        if c == "]":                          # OSC: BEL or ST (ESC\) terminates
            return len(s) if ("\x07" in tail[2:] or "\x1b\\" in tail[2:]) else i
        if c in "PX^_":                       # DCS/SOS/PM/APC: ST only (BEL is content)
            return len(s) if "\x1b\\" in tail[2:] else i
        return len(s)                         # 2-char ESC-x escape is complete

    def feed(self, piece):
        self._raw += piece
        cut = self._stable_len(self._raw)
        stable_raw, self._raw = self._raw[:cut], self._raw[cut:]
        # Bound a pathological unterminated escape (a hostile endpoint streaming
        # ESC[ + endless params) WITHOUT breaking its semantics. `_raw` here is
        # exactly one still-open escape (starts with ESC); its CONTENT is
        # discarded regardless, so drop the bloated MIDDLE while keeping the
        # ESC-prefix + recent tail. `_raw` (and each _stable_len rescan) stays
        # bounded, yet the escape remains "open" so when its terminator finally
        # arrives — or at flush — it is removed exactly as redact() would,
        # instead of leaking its middle as literal text. Any terminator is short
        # and recent, so it can only be in the kept tail, never the dropped span.
        if len(self._raw) > _MAX_ESCAPE_HOLD:
            self._raw = self._raw[:2] + self._raw[-_ESCAPE_KEEP_TAIL:]
        if stable_raw:
            self._san += redact(stable_raw, "")   # sanitize only (escape-free)
        return self._emit(hold=self._keep)

    def _raw_commit_len(self, seg, red_target):
        """RAW chars of escape-free `seg` whose key-redaction is <= red_target
        redacted chars, stopping on a KEY BOUNDARY (never mid-key / mid-
        placeholder). `seg` is escape-free so redact() only substitutes the
        fixed key → placeholder; every other char maps 1:1."""
        if not self._key:
            return min(len(seg), red_target)
        klen, plen, n = len(self._key), len(_KEY_PLACEHOLDER), len(seg)
        raw_i = red_out = 0
        while raw_i < n:
            if seg.startswith(self._key, raw_i):
                if red_out + plen > red_target:
                    break                     # whole placeholder wouldn't fit
                raw_i += klen
                red_out += plen
            else:
                if red_out + 1 > red_target:
                    break
                raw_i += 1
                red_out += 1
        return raw_i

    def _emit(self, hold):
        # `_san` is only the un-emitted tail, so this redact() is O(tail).
        # Redacting the whole tail makes a key straddling the hold boundary a
        # stable placeholder; commit the largest key-safe raw prefix whose
        # redaction fits within len(red)-hold, emit it, and DROP it from `_san`.
        red = redact(self._san, self._key) if self._key else self._san
        target = len(red) - hold if hold else len(red)
        if target <= 0:
            return ""
        raw_i = self._raw_commit_len(self._san, target)
        if raw_i <= 0:
            return ""
        out = (redact(self._san[:raw_i], self._key)
               if self._key else self._san[:raw_i])
        self._san = self._san[raw_i:]     # drop the committed, key-safe prefix
        return out

    def flush(self):
        if self._raw:                 # commit any held (possibly incomplete) escape
            self._san += redact(self._raw, "")
            self._raw = ""
        return self._emit(hold=0)


