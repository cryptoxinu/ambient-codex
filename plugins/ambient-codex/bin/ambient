# ── ambient config: one clean home for user settings (no env editing) ──────
# Every write goes through save_config_values (atomic, 0600, merge-preserving);
# every read uses the SAME env-or-config resolvers the rest of the CLI already
# uses, so a `config set` takes effect with NO reader change. set/unset may touch
# ONLY the CONFIG_SETTINGS whitelist below — never the model/mode/curation/
# endpoint/key keys (those keep their own commands). The API key is never a config
# value: it can only be set via `ambient-codex setup` (hidden input, user's terminal).


# Whitelist: friendly name → (env key, validator/normalizer, default, current
# reader, value-syntax hint). This tuple is the ONLY set of keys set/unset can
# write — the guarantee that a settings change can never clobber another command's
# config. current() reads the SAME resolver the CLI uses at runtime (zero network).
CONFIG_SETTINGS = (
    {"name": "streaming", "env": "AMBIENT_PROGRESS", "default": "on", "how": "on|off",
     "validate": _config_norm_bool,
     "current": lambda conf: "on" if _progress_from_env_or_conf(conf) else "off"},
    {"name": "fallback", "env": "AMBIENT_FALLBACK", "default": "off", "how": "on|off",
     "validate": _config_norm_bool,
     "current": lambda conf: "on" if str(
         os.environ.get("AMBIENT_FALLBACK") or conf.get("AMBIENT_FALLBACK") or ""
     ).strip().lower() in ("1", "on", "true") else "off"},
    {"name": "reference-price", "env": "AMBIENT_REFERENCE_PRICE", "default": "3/15",
     "how": "<in/out>", "validate": _config_norm_price,
     "current": lambda conf: "/".join(
         _config_fmt_num(x) for x in resolve_reference_price(conf))},
    {"name": "savings", "env": "AMBIENT_SAVINGS", "default": "off", "how": "on|off",
     "validate": _config_norm_bool,
     "current": lambda conf: "on" if _savings_enabled(conf) else "off"},
)
_CONFIG_BY_NAME = {s["name"]: s for s in CONFIG_SETTINGS}


