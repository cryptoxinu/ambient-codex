def refuse_if_secrets(labeled_chunks, allow):
    """Refuse likely credentials while reporting bounded locations, never content."""
    if allow:
        return
    hits = _secrets_core.secret_hits(labeled_chunks)
    if hits:
        msg = (
            "refusing to send — content that looks like "
            f"credentials at: {', '.join(hits)}. Redact those lines, or pass "
            "--allow-secrets if they are false positives (e.g. variable names)."
        )
        _fail_exit(None, _argv_command(), "secrets", msg,
                   prose=f"ambient [secrets]: {msg}")


USAGE_MAX_BYTES = 5_000_000  # cap the ledger; trim oldest lines past this
USAGE_TRIM_KEEP_LINES = 20_000  # how many newest ledger lines a trim keeps


def _retry_delay(base, headers=None):
    """Backoff with random jitter, honoring a Retry-After header (clamped to 60s)
    when present. Jitter breaks the lockstep that makes 3 fan-out workers
    re-hit the limiter together (thundering herd)."""
    hint = 0.0
    if headers is not None:
        ra = headers.get("Retry-After")
        if ra:
            try:
                hint = float(ra)
            except (TypeError, ValueError):
                hint = 0.0
    delay = min(max(float(base), hint), 60.0)
    return delay + random.uniform(0, 0.5 * delay)


CACHE_DIR = os.path.join(STATE_DIR, "cache")
CACHE_MAX_FILES = 4000            # LRU-ish cap; oldest pruned past this
CACHE_TTL_DEFAULT = 7 * 86400     # a cached chunk older than this is ignored


def _cache_key(model, system, chunk, max_tokens, temperature,
               response_format=None, salt=None):
    """Content address for one chunk call. MUST include model + max_tokens
    (per-model budgets differ) AND response_format — a strict-schema model shares
    the same system prompt for prose vs --json, so omitting it would serve cached
    prose into the JSON reducer or vice-versa. `salt`
 namespaces otherwise-identical calls — each --best-of sample
    index gets its OWN cache entry so re-runs resume per sample; salt=None is
    byte-identical to the pre-salt key."""
    return _cache_store.cache_key(
        model, system, chunk, max_tokens, temperature, response_format, salt
    )


def _cache_get(key, ttl):
    return _cache_store.cache_get(CACHE_DIR, key, ttl)


def _cache_put(key, text):
    _cache_store.cache_put(
        CACHE_DIR, key, text, CACHE_MAX_FILES, _private_dir
    )


def log_usage(model, usage, input_chars=None):
    """Best-effort local metering (Ambient has no balance endpoint). Builds the
    enriched ledger record here — token counts, observed char telemetry, the
    priced cost, and the frontier reference in force at call time — then
    delegates fail-open, lock-serialized persistence to
    ``ambient_codex.usage_store``. A skipped trim only lets the ledger grow a
    little; a lost line loses spend signal, so the store spools rather than
    dropping a line under lock contention."""
    try:
        record = {
            "ts": int(time.time()),
            "model": model,
            "in": usage.get("prompt_tokens", 0),
            "out": usage.get("completion_tokens", 0),
        }
        # telemetry (additive): store the observed input CHAR count
        # alongside REAL token usage so observed_cpt() can learn each model's
        # true chars-per-token. Estimated usage is skipped — its token counts
        # were themselves derived from chars via the static constant, so the
        # ratio would be a circular echo, not an observation.
        if (input_chars and not usage.get("_estimated")
                and isinstance(input_chars, (int, float))
                and isinstance(record["in"], (int, float))
                and record["in"] > 0):
            record["chars"] = int(input_chars)
        # (additive; old records without these fields still parse):
        # price the run NOW and pin the frontier reference in force, so
        # `ambient usage` computes historical savings against what was true
        # at call time even if the default/env changes later. Estimated
        # token counts (salvage path) are marked so they stay honest.
        try:
            if usage.get("_estimated"):
                record["est"] = True
            cost, assumed = usage_cost(model, usage)
            if not assumed:  # an ASSUMED worst-case figure is not a real cost
                # FULL precision — round(…,6) flattened sub-microdollar calls
                # to 0, and thousands of them aggregated as free (a
                # fabricated ~100% saving). Round only at display.
                record["cost"] = cost
            ref = resolve_reference_price()
            record["ref"] = [ref[0], ref[1]]
        except Exception:  # enrichment must never cost us the base record
            pass
        line = json.dumps(record) + "\n"
        _usage_store.append_line(
            line,
            usage_path=USAGE_PATH,
            max_bytes=USAGE_MAX_BYTES,
            trim_keep_lines=USAGE_TRIM_KEEP_LINES,
            lock_wait_s=_LEDGER_LOCK_WAIT_S,
            private_dir=_private_dir,
            fs_lock=_fs_lock,
            pid_alive=_pid_alive,
        )
    except Exception:  # metering is best-effort; never break the caller's turn
        pass


def usage_exit(msg):
    """Semantic usage errors share argparse's exit code (EX_USAGE=64) so an
    agentic caller can tell 'wrong invocation' from 'runtime failure'. Under
    --json the same error is ALSO emitted as a parseable envelope (exit 64)."""
    if _json_in_argv():
        emit_json_error("usage", "usage", msg, exit_code=EXIT_USAGE)
    print(f"ambient: {msg}", file=sys.stderr)
    sys.exit(EXIT_USAGE)



def stream_completion(api_url, api_key, payload, timeout, on_delta=None):
    """Facade seam for the extracted dependency-injected SSE transport."""
    return _streaming.stream_completion(
        api_url, api_key, payload, timeout, on_delta,
        opener=urllib.request.urlopen,
        network_error=NetworkError,
        stall_error=StallError,
        stream_line_max=STREAM_LINE_MAX,
        heartbeat_s=HEARTBEAT_S,
        hard_wall_s=HARD_WALL_S,
        noprogress_s=NOPROGRESS_S,
        progress_enabled=progress_display_enabled,
        stderr=sys.stderr,
        stderr_is_tty=_stderr_is_tty,
    )


# Per-Session catalog memo kept OUTSIDE the frozen value object so a Session
# stays fully immutable (no interior-mutable field). Keyed weakly by Session
# identity (eq=False → identity hash), so entries vanish when the Session is
# collected. Reads/writes for a given Session are serialized by its own
# _catalog_lock; distinct Sessions touch distinct keys (GIL-atomic dict ops).
_SESSION_CATALOG = weakref.WeakKeyDictionary()


@dataclasses.dataclass(frozen=True, eq=False)
class Session:
    """Transport context for the engine: ONE frozen object in
    place of the (api_key, api_url, conf) triple threaded loose through every
    engine call. `transport` is an injectable stream_completion-compatible
    callable — None means "resolve the module-level stream_completion at call
    time" so existing test monkeypatching keeps working. `catalog()` memoizes
    ONE safe_catalog fetch per Session (write-once cache cell; the instance
    itself is immutable — no field is ever reassigned)."""

    api_url: str
    api_key: str
    conf: dict = dataclasses.field(default_factory=dict)
    transport: object = None  # callable(api_url, api_key, payload, timeout,
    #                           on_delta=None) -> (status, body)
    _catalog_lock: object = dataclasses.field(
        default_factory=threading.Lock, repr=False, compare=False)

    def catalog(self):
        """Model catalog, fetched AT MOST once per Session (degrades to []
        exactly like safe_catalog — a degraded [] is memoized too, so a
        Session never turns one logical fetch into a retry storm). The memo
        lives in the module-level _SESSION_CATALOG (keyed by this Session) so
        the Session itself never mutates a field."""
        with self._catalog_lock:
            if self not in _SESSION_CATALOG:
                _SESSION_CATALOG[self] = safe_catalog(
                    self.api_url, self.api_key)
            return _SESSION_CATALOG[self]


def _session_or(session, api_key, api_url, conf=None):
    """Normalize the loose (api_key, api_url[, conf]) triple to ONE Session.
    Engine functions accept either form: callers
    that already hold a Session pass it through; legacy positional callers
    get an equivalent Session built on the spot."""
    if session is not None:
        return session
    return Session(api_url=api_url, api_key=api_key, conf=conf or {})


DEFAULT_BUDGET_ESCALATIONS = 1
MAX_BUDGET_ESCALATIONS = 2


@dataclasses.dataclass(frozen=True)
class RequestSpec:
    """The ENGINE's frozen request-knob carrier: every knob the
    engine (complete/chat/run_map_reduce/run_one_audit/_best_of_chat/
    _ask_consensus/run_cross_file_pass + the helpers they call) reads off the
    request. Built ONCE from the parsed argparse.Namespace at the cmd_*
    boundary via from_args; every variant (retry budget shrink/escalation,
    --fallback re-derivation, SACRED _no_fallback workers, best-of cache
    salts) is a dataclasses.replace — argparse.Namespace never travels inside
    the engine and nothing is ever mutated in place.

    ⛔ DEFAULT PARITY: each field's default MUST equal the default the engine
    used when it read the knob off a raw Namespace (getattr(args, X, D) → D;
    argparse-owned flags → their add_common_flags default). from_args builds
    fields via getattr(args, name, field-default), so a Namespace lacking a
    knob behaves exactly like the old getattr read by construction."""

    max_tokens: object = None            # argparse default (auto-sized later)
    temperature: float = 0.1             # argparse default
    timeout: int = DEFAULT_TIMEOUT_S     # argparse default
    response_format: object = None       # getattr(..., None) everywhere
    system: object = None                # getattr(..., None) (ask/chat)
    raw: bool = False                    # argparse store_true
    json: bool = False                   # getattr(..., False)
    format: object = None                # getattr(..., None) (_json_mode)
    allow_partial: bool = False          # getattr(..., False)
    allow_cost: bool = False             # getattr(..., False) (spend gates)
    yes: bool = False                    # getattr(..., False) (spend gates)
    parallel: object = None              # getattr(..., None) (_resolve_parallel)
    no_cache: bool = False               # getattr(..., False)
    cache_ttl: object = None             # getattr(..., None)
    fallback: bool = False               # getattr(..., False)
    consensus: object = None             # argparse default (ask --consensus)
    _no_fallback: bool = False           # getattr(..., False) — SACRED guard
    _auto_budget: bool = False           # getattr(..., False)
    _cache_salt: object = None           # getattr(..., None) — best-of lanes
    escalation_ceiling: int = MAX_AUTO_BUDGET_TOKENS  # getattr default
    # Build generation is the sole lane that raises this to two. A second
    # escalation is justified only after a model spent a full first retry on
    # reasoning without emitting a file; every other lane preserves one retry.
    max_budget_escalations: int = DEFAULT_BUDGET_ESCALATIONS
    # True (default) = SINGLE-CALL lane — complete()
    # re-gates a live --fallback swap per call (main thread; sys.exit on a
    # refusal is correct). Fan-out workers (map/consensus/best-of) set False:
    # their batch gate already reserved the swap exposure UP FRONT
    # (fallback-aware estimates), and a per-worker gate cannot compose with
    # concurrent fan-out — the same-process fleet reservation REFRESHES to
    # max(batch, one alt) instead of adding (N alt swaps under-reserved
    # N-fold), and a refusal would SystemExit inside a pool thread.
    gate_fallback: bool = True           # getattr(..., True)

    @classmethod
    def from_args(cls, args):
        """Normalize an argparse.Namespace (or an existing RequestSpec —
        passed through untouched) to a frozen RequestSpec. Field defaults
        double as the getattr defaults, so missing Namespace attributes
        resolve exactly as the engine's old getattr reads did."""
        if isinstance(args, cls):
            return args
        return cls(**{f.name: getattr(args, f.name, f.default)
                      for f in dataclasses.fields(cls)})

    def with_output_budget(self, profile, input_chars=None):
        """Frozen twin of apply_output_budget: a NEW spec with max_tokens/
        _auto_budget/escalation_ceiling resolved for `profile` (same
        _resolve_output_budget core — the two carriers can never drift)."""
        resolved, auto = _resolve_output_budget(
            self.max_tokens, profile, input_chars)
        ceiling = _context_safe_escalation_ceiling(
            profile, input_chars, _effective_cpt(profile.model))
        return dataclasses.replace(
            self, max_tokens=resolved, _auto_budget=auto,
            escalation_ceiling=max(resolved, ceiling))


@dataclasses.dataclass(frozen=True)
class AttemptState:
    """ONE attempt of complete()'s retry/fallback ladder.
    Immutable: every guard (stall retry, budget shrink, model fallback,
    budget escalation) computes the NEXT attempt via dataclasses.replace —
    never by mutating shared state. The four flags are INDEPENDENT and only
    ever flip False→True, so the ladder is bounded by construction."""

    model: str
    messages: list
    spec: RequestSpec # per-attempt frozen knobs (replaced per variant)
    stall_retried: bool = False
    budget_escalations: int = 0
    fallback_retried: bool = False
    budget_shrunk: bool = False
    attempt_no: int = 0


# Hard ceiling on normal calls: the initial attempt + one retry per independent
# guard flag. Build generation may add one more output escalation, still capped
# by MAX_BUDGET_ESCALATIONS in _budget_escalation_limit().
MAX_COMPLETE_ATTEMPTS = 5


def _reasoning_str(*vals):
    """First non-empty STRING among candidate reasoning fields, stripped. An
    untrusted response may carry a scalar `reasoning`/`reasoning_content`
    (e.g. 1) — `(v or "").strip()` would AttributeError on it."""
    for v in vals:
        if isinstance(v, str) and v.strip():
            return v.strip()
    return ""


def _budget_escalation_limit(value):
    """Clamp an internal retry policy to the small, safe engine maximum."""
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        parsed = DEFAULT_BUDGET_ESCALATIONS
    return max(DEFAULT_BUDGET_ESCALATIONS,
               min(MAX_BUDGET_ESCALATIONS, parsed))


