# Completions STREAM: liveness is judged by data flow, not total duration. A
# healthy generation can run for ages; silence beyond the per-op timeout
# (args.timeout, default 300s) means a hung worker and is caught immediately.
# AMBIENT_HARD_WALL_S / AMBIENT_NOPROGRESS_S let a very long build raise these.
HARD_WALL_S = _env_pos_int("AMBIENT_HARD_WALL_S", 5400, floor=60)
# A wedged worker can keep the socket alive (empty deltas / keep-alives) while
# emitting NO new content or reasoning — that fools a pure silence timeout. If
# nothing useful grows for this long, treat it as a stall.
NOPROGRESS_S = _env_pos_int("AMBIENT_NOPROGRESS_S", 150, floor=10)
# The streamed heartbeat ("…writing (N chars, Xs)") and the build phase lines
# ("generating <paths> [X/Y]") are pure UX. This toggle gates ONLY their DISPLAY —
# the smart-timeout guards above (HARD_WALL_S / NOPROGRESS_S / stall) are safety
# and stay enforced no matter what, so silencing progress never weakens them.
# Default ON. Precedence: --progress/--no-progress flag > AMBIENT_PROGRESS env >
# config file > on. Resolved once by main(); a module holder keeps stream_completion
# (which has no args/conf) from re-reading config on every ~1s tick.
_PROGRESS_DISPLAY = {"resolved": None}


def _progress_from_env_or_conf(conf):
    """AMBIENT_PROGRESS=off|0|false|no (env, then config) silences the display."""
    raw = os.environ.get("AMBIENT_PROGRESS")
    if raw is None:
        raw = conf.get("AMBIENT_PROGRESS") if conf else None
    if raw is None:
        return True
    return str(raw).strip().lower() not in ("off", "0", "false", "no")


def _resolve_progress_display(args, conf):
    """flag beats env beats config beats the on-default (see _PROGRESS_DISPLAY)."""
    flag = getattr(args, "progress", None)   # store_true/false; absent → None
    if flag is not None:
        return bool(flag)
    return _progress_from_env_or_conf(conf)


def progress_display_enabled():
    """Whether to SHOW streamed progress. Uses the value main() resolved; before
    that (e.g. a direct unit-test call) it honors AMBIENT_PROGRESS so the env alone
    always works. NEVER affects the hard-wall / no-progress / stall guards."""
    v = _PROGRESS_DISPLAY["resolved"]
    return _progress_from_env_or_conf(None) if v is None else v


