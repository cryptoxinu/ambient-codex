class _Parser(argparse.ArgumentParser):
    """Usage errors exit 64 (EX_USAGE), not argparse's default 2 — exit 2 is
    reserved for PARTIAL results, and agentic callers must be able to tell
    "my flags were wrong" from "coverage was incomplete". Mistyped subcommands
    get a did-you-mean."""

    def error(self, message):
        extra = ""
        m = re.search(r"invalid choice: '([^']+)'", message)
        if m:
            cand = re.search(r"choose from (.+)\)", message)
            choices = ([c.strip().strip("'") for c in cand.group(1).split(",")]
                       if cand else [])
            close = difflib.get_close_matches(m.group(1), choices, n=1, cutoff=0.5)
            if close:
                extra = f"\ndid you mean: {close[0]}?"
        if _json_in_argv():
            # The --json failure contract is TOTAL: even argparse's own
            # rejections reach a machine caller as the envelope (exit 64),
            # never prose. --help and successful parses are untouched.
            emit_json_error(_argv_command(), "usage", f"{message}{extra}",
                            exit_code=EXIT_USAGE)
        self.print_usage(sys.stderr)
        self.exit(EXIT_USAGE,
                  f"{self.prog}: error: {message}{extra}\ntry: {self.prog} -h\n")


def add_common_flags(parser):
    return _cli_parser.add_common_flags(
        parser, default_timeout_s=DEFAULT_TIMEOUT_S,
        max_parallel_chunks=MAX_PARALLEL_CHUNKS)


def _add_best_of_flag(parser):
    return _cli_parser.add_best_of_flag(parser, best_of_max=BEST_OF_MAX)


# --- Declarative command registry -------------------------------
# ONE table drives BOTH argparse construction and dispatch — replacing the old
# dual mechanism (a pre-credential if-chain + a post-credential handlers dict).
# Each entry:
#   name           the subcommand
#   configure      builds the subparser (owns its own flags/help text)
#   handler        NAME of the handler function — resolved via module globals
#                  at dispatch time (tests monkeypatch cmd_* attributes)
#   needs_key      True → load_config() first (exit 3 when unconfigured) and
#                  handler(args, api_key, api_url, conf); False → handler(args)
#   pre_env        dispatch BEFORE the HOME check / numeric clamps (version)
#   keyless_route  NAME of a predicate(args) -> handler-name-or-None: lets a
#                  needs_key command short-circuit a pure-local sub-mode
#                  (audit --install-hook) before any credentials are needed


def _configure_version(sub):
    return _cli_parser.configure_version(sub)


def _configure_models(sub):
    return _cli_parser.configure_models(sub)


def _configure_curate(sub):
    return _cli_parser.configure_curate(sub)


