# Above every price observed in the live catalog — used as the worst-case
# price when a model's real pricing is unknown, so cost estimates never
# under-count.
ASSUMED_MAX_INPUT_PRICE = 2.0    # per Mtok
ASSUMED_MAX_OUTPUT_PRICE = 8.0   # per Mtok


