class _Parser(argparse.ArgumentParser):
    """Usage errors exit 64 (EX_USAGE), not argparse's default 2 — exit 2 is
    reserved for PARTIAL results, and agentic callers must be able to tell
    "my flags were wrong" from "coverage was incomplete". Mistyped subcommands
    get a did-you-mean."""

    def error(self, message):
        extra = ""
        m = re.search(r"invalid choice: '([^']+)'", message)
        if m:
            cand = re.search(r"choose from (.+)\)", message)
            choices = ([c.strip().strip("'") for c in cand.group(1).split(",")]
                       if cand else [])
            close = difflib.get_close_matches(m.group(1), choices, n=1, cutoff=0.5)
            if close:
                extra = f"\ndid you mean: {close[0]}?"
        if _json_in_argv():
            # The --json failure contract is TOTAL: even argparse's own
            # rejections reach a machine caller as the envelope (exit 64),
            # never prose. --help and successful parses are untouched.
            emit_json_error(_argv_command(), "usage", f"{message}{extra}",
                            exit_code=EXIT_USAGE)
        self.print_usage(sys.stderr)
        self.exit(EXIT_USAGE,
                  f"{self.prog}: error: {message}{extra}\ntry: {self.prog} -h\n")


