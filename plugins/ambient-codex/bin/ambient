def _cmd_version(args):
    print(f"ambient {__version__}")


def _cmd_models_keyless(args):
    # The catalog endpoint is unauthenticated — let a curious stranger see
    # the live network BEFORE creating an account (pre-signup funnel).
    conf = read_config_file()
    key, _ = resolve_key_and_backend(conf)
    try:
        cmd_models(args, key or "none", resolve_api_url(conf), conf)
    except NetworkError as err:
        sys.exit(f"ambient [network]: {err}")


def _cmd_trust_url_dispatch(args):
    if args.reset:
        cmd_trust_url_reset()
    elif args.url:
        cmd_trust_url(args)
    else:
        usage_exit("trust-url needs a URL (or --reset)")


def _cmd_codex_keyless(args):
    cmd_codex(args, None, None, None)


def _audit_keyless_route(args):
    """audit --install-hook / --uninstall-hook is pure hooks-file management
    (7d): no key, no network — it must work before any credentials exist."""
    if getattr(args, "install_hook", None) or getattr(args, "uninstall_hook", None):
        return "cmd_audit_hook"
    return None


COMMANDS = _cli_dispatch.make_command_registry({
    "version": _configure_version, "models": _configure_models,
    "curate": _configure_curate, "setup": _configure_setup,
    "link": _configure_link, "uninstall": _configure_uninstall,
    "cache": _configure_cache, "trust-url": _configure_trust_url,
    "usage": _configure_usage, "mode": _configure_mode,
    "config": _configure_config, "control": _configure_control,
    "doctor": _configure_doctor, "use": _configure_use,
    "ask": _configure_ask, "audit": _configure_audit,
    "map": _configure_map, "code": _configure_code,
    "chat": _configure_chat, "build": _configure_build,
    "agent": _configure_agent, "codex": _configure_codex,
})


def _registry_handler(name):
    """Resolve a registry handler by NAME at dispatch time, so tests that
    monkeypatch module attributes (amb.cmd_ask = stub) keep working."""
    return globals()[name]


def build_parser():
    """Construct the fully-configured top-level parser (extracted so tests and
    main share one definition)."""
    return _cli_dispatch.build_parser(
        parser_class=_Parser, description=__doc__, version=__version__,
        commands=COMMANDS)


def _parse_args_with_stdin_dash(parser):
    """parse_args, but rescue a lone stdin sentinel '-' that argparse's greedy
    nargs='*' positional orphans when it TRAILS a value option — e.g.
    `ask "prompt" -m MODEL -`, the most natural order, which otherwise errors
    with 'unrecognized arguments: -' (stress test F03). For `ask` the '-' is
    injected into the prompt (its handler reads stdin as extra context); for
    every other command a lone trailing '-' is simply DROPPED — audit/map
    already auto-read piped stdin, and code takes no stdin — so the natural
    order never errors on any command (Codex round 2). Any OTHER leftover is
    still a real usage error, exactly like parse_args."""
    return _cli_dispatch.parse_args_with_stdin_dash(parser)


def main():
    parser = build_parser()

    # Never accept a key as a command-line argument: argv lands in shell
    # history and process listings. Refuse BEFORE argparse
    # can echo the token back in an 'unrecognized arguments' error. `config` is
    # covered too — none of its real values are secret-shaped, so a key-looking
    # token there is a mistake to refuse, not to echo (Codex 2026-07-08).
    if len(sys.argv) > 2 and sys.argv[1] in ("setup", "config", "control"):
        _keyname = ("key", "api-key", "apikey", "ambient-api-key")
        for tok in sys.argv[2:]:
            # An explicit key ASSIGNMENT (`key=…`, `--api-key=…`) is never a valid
            # arg here — refuse it regardless of the value's SHAPE, so even a short
            # key can't be echoed by argparse's 'unrecognized arguments' error
            # (Codex 2026-07-08).
            if "=" in tok and tok.lstrip("-").split("=", 1)[0].strip().lower(
            ).replace("_", "-") in _keyname:
                sys.exit(
                    "ambient: don't pass an API key on the command line — it lands "
                    f"in your shell history. Run `{LAUNCHER_NAME} setup` (interactive, "
                    f"hidden input) instead, and ROTATE that key at {KEY_CONSOLE_URL}."
                )
            if tok.startswith("-"):
                # A bare flag is safe, but `--key=sk-...` smuggles the secret
                # inside the token; inspect the value after the first '=' too,
                # else argparse echoes it in its 'unrecognized arguments' error.
                if "=" not in tok:
                    continue
                tok = tok.split("=", 1)[1]
            if (len(tok) >= 20 and re.fullmatch(r"[A-Za-z0-9_.\-]{20,}", tok)) \
                    or any(p.search(tok) for p in SECRET_PATTERNS):
                sys.exit(
                    "ambient: it looks like you passed your API key on the "
                    "command line — it is now in your shell history. Run "
                    f"`{LAUNCHER_NAME} setup` (interactive, hidden input) instead, and "
                    f"ROTATE that key at {KEY_CONSOLE_URL}."
                )
    args = _parse_args_with_stdin_dash(parser)
    spec = _cli_dispatch.find_command(COMMANDS, args.command)
    if spec is not None and spec.get("pre_env"):
        # `ambient version` must work even before HOME/config resolve.
        _registry_handler(spec["handler"])(args)
        return
    if args.command is None:  # bare `ambient` → onboarding banner, not an error
        print(build_banner())
        return
    # An UNRESOLVED home leaves a LEADING '~' (os.path.expanduser passthrough).
    # Match only that — not any '~' in the path, which false-positives on
    # Windows 8.3 short paths like C:\Users\RUNNER~1\... (a resolved home).
    if CONFIG_PATH.startswith("~"):
        _fail_exit(
            args, _argv_command(), "config",
            "cannot resolve your home directory (HOME unset). "
            "Set HOME and retry."
        )
    # Foolproofing: clamp nonsensical numeric args instead of letting them run.
    if getattr(args, "max_tokens", None) is not None:
        if args.max_tokens < MIN_OUTPUT_TOKENS:
            print(
                f"ambient: --max-tokens {args.max_tokens} is too low for a reasoning "
                f"model (it needs room to think AND answer) — raising to "
                f"{MIN_OUTPUT_TOKENS}",
                file=sys.stderr,
            )
            args.max_tokens = MIN_OUTPUT_TOKENS
        else:
            args.max_tokens = normalize_requested_max_tokens(args.max_tokens)
    if getattr(args, "temperature", None) is not None:
        t = args.temperature
        if t != t or not (0.0 <= t <= 2.0):  # NaN or out of range
            fixed = 0.1 if t != t else max(0.0, min(2.0, t))
            print(
                f"ambient: --temperature {t} is invalid — using {fixed}",
                file=sys.stderr,
            )
            args.temperature = fixed
    if getattr(args, "timeout", None) is not None and args.timeout <= 0:
        print(
            f"ambient: --timeout must be positive — using {DEFAULT_TIMEOUT_S}s",
            file=sys.stderr,
        )
        args.timeout = DEFAULT_TIMEOUT_S
    # Key-less commands work before any credentials exist:
    if not spec["needs_key"]:
        _registry_handler(spec["handler"])(args)
        return
    # A needs_key command may still expose a pure-local sub-mode
    # (audit --install-hook) that must run without credentials:
    route = spec.get("keyless_route")
    if route:
        alt = _registry_handler(route)(args)
        if alt:
            _registry_handler(alt)(args)
            return
    api_key, api_url, conf = load_config()
    # Fold --progress/--no-progress + AMBIENT_PROGRESS (env, then config) into the
    # module holder now that conf is loaded — every streaming command reaches this
    # line before it streams, so the display gate has a resolved value.
    _PROGRESS_DISPLAY["resolved"] = _resolve_progress_display(args, conf)
    try:
        _registry_handler(spec["handler"])(args, api_key, api_url, conf)
    except ChatError as err:
        # A map-reduce that exhausts its retries raises ChatError up here — show
        # it as the clean classified diagnosis, not a generic internal error.
        # A --json caller gets the machine-readable error envelope instead.
        if _json_mode(args):
            emit_json_error(args.command, err.category, err.diagnosis, api_key)
        sys.exit(f"ambient [{err.category}]: {err.diagnosis}")
    except NetworkError as err:
        if _json_mode(args):
            emit_json_error(args.command, "network", str(err), api_key)
        sys.exit(
            f"ambient [network]: {err}. Check your internet connection; if other "
            "sites work, Ambient may be unreachable — run: ambient-codex doctor"
        )


def shielded_main():
    """No raw traceback ever reaches the user: every unexpected failure becomes
    a clean, redacted, one-line diagnosis. AMBIENT_DEBUG=1 restores tracebacks."""
    # Windows/legacy-locale consoles default to a codepage (e.g. cp1252) that
    # can't encode the arrows/box-drawing/CJK the CLI emits, so plain output
    # would crash with UnicodeEncodeError. Force UTF-8 on the real streams. No-op
    # where already UTF-8, on a non-reconfigurable stream, or under test capture.
    for _stream in (sys.stdout, sys.stderr):
        try:
            _stream.reconfigure(encoding="utf-8")
        except (AttributeError, ValueError, OSError):
            pass
    try:
        main()
    except (KeyboardInterrupt, EOFError):
        sys.stderr.write("\nambient: cancelled\n")
        sys.exit(130)
    except SystemExit:
        raise
    except NetworkError as err:
        msg = (f"{err}. Check your internet connection; if other "
               "sites work, Ambient may be unreachable — run: ambient-codex doctor")
        _fail_exit(None, _argv_command(), "network", msg,
                   prose=f"ambient [network]: {msg}")
    except Exception as err:  # noqa: BLE001 — the whole point is a clean floor
        if os.environ.get("AMBIENT_DEBUG") == "1":
            raise
        # Resolve the REAL key (env > Keychain > file) so redaction works even
        # when the key is in the macOS Keychain and absent from the env file
        #.
        key = ""
        try:
            key = resolve_key_and_backend(read_config_file())[0] or ""
        except Exception:  # noqa: BLE001
            pass
        detail = redact(f"{type(err).__name__}: {err}", key)[:300]
        msg = (f"unexpected error ({detail}). Nothing was harmed. "
               "Run 'ambient-codex doctor' to check the basics; set AMBIENT_DEBUG=1 to see "
               "full details.")
        # Even the last-resort floor honors the --json contract (redacted).
        _fail_exit(None, _argv_command(), "internal", msg, api_key=key,
                   prose=f"ambient [internal]: {msg}")


if __name__ == "__main__":
    shielded_main()
