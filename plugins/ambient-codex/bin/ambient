    globals(), "add_common_flags _add_best_of_flag _configure_version _configure_models _configure_curate _configure_setup _configure_link _configure_uninstall cmd_uninstall _configure_cache _configure_trust_url _configure_usage _configure_mode _configure_config _configure_control _configure_doctor _configure_use _configure_ask _configure_audit _configure_map _configure_code _configure_chat _configure_build _configure_agent _configure_codex _cmd_version _cmd_models_keyless _cmd_trust_url_dispatch _cmd_codex_keyless _audit_keyless_route _registry_handler build_parser _parse_args_with_stdin_dash main shielded_main")


# --- Declarative command registry -------------------------------
# ONE table drives BOTH argparse construction and dispatch — replacing the old
# dual mechanism (a pre-credential if-chain + a post-credential handlers dict).
# Each entry:
#   name           the subcommand
#   configure      builds the subparser (owns its own flags/help text)
#   handler        NAME of the handler function — resolved via module globals
#                  at dispatch time (tests monkeypatch cmd_* attributes)
#   needs_key      True → load_config() first (exit 3 when unconfigured) and
#                  handler(args, api_key, api_url, conf); False → handler(args)
#   pre_env        dispatch BEFORE the HOME check / numeric clamps (version)
#   keyless_route  NAME of a predicate(args) -> handler-name-or-None: lets a
#                  needs_key command short-circuit a pure-local sub-mode
#                  (audit --install-hook) before any credentials are needed


COMMANDS = _cli_dispatch.make_command_registry({
    "version": _configure_version, "models": _configure_models,
    "curate": _configure_curate, "setup": _configure_setup,
    "link": _configure_link, "uninstall": _configure_uninstall,
    "cache": _configure_cache, "trust-url": _configure_trust_url,
    "usage": _configure_usage, "mode": _configure_mode,
    "config": _configure_config, "control": _configure_control,
    "doctor": _configure_doctor, "use": _configure_use,
    "ask": _configure_ask, "audit": _configure_audit,
    "map": _configure_map, "code": _configure_code,
    "chat": _configure_chat, "build": _configure_build,
    "agent": _configure_agent, "codex": _configure_codex,
})


