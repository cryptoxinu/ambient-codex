    return _cli_parser.configure_link(sub)


def _configure_uninstall(sub):
    return _cli_parser.configure_uninstall(sub, state_dir=STATE_DIR)


def cmd_uninstall(args):
    """Cleanly offboard Ambient Codex. Touches ONLY this install's own resources —
    the ambient-codex keychain item, ~/.config/ambient-codex, and the ambient-codex
    launcher — never another Ambient install's key, state, launcher, or git hooks.

    Removing the plugin itself is a Codex action, so we print the command rather than
    run it."""
    purge = getattr(args, "purge", False)
    # Defence in depth: _state_dir() already refuses a foreign root at import, but
    # never scrub or delete without re-confirming STATE_DIR is ours right here.
    if foreign_root(STATE_DIR) is not None:
        sys.exit(f"ambient: refusing to uninstall — state root {STATE_DIR} is inside "
                 "another Ambient install's tree.")
    if not getattr(args, "yes", False) and sys.stdin.isatty():
        print("This removes Ambient Codex's API key and PATH launcher"
              + (f", and deletes {STATE_DIR}" if purge else "")
              + ".")
        print("It does NOT touch any other Ambient install.")
        try:
            if input("Continue? [y/N] ").strip().lower() not in ("y", "yes"):
                print("Cancelled.")
                return
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled.")
            return

    # 1. Key: keychain item (ambient-codex only) + the env-file entry.
    kc_ok = keychain_delete()
    save_config_values({"AMBIENT_API_KEY": None, "AMBIENT_KEY_BACKEND": None})
    if kc_ok and not keychain_read():
        print("• API key removed (keychain + env file).")
    else:
        print(f"• Could not fully remove the key from the OS keychain (locked?). "
              f"Remove it manually: Keychain Access → search '{KEYCHAIN_SERVICE}'.",
              file=sys.stderr)

    # 2. PATH launcher: cmd_link refuses anything not ours. `--dir` lets the user
    # point at a launcher they created with `link --dir`; the default covers
    # ~/.local/bin. Launchers linked into OTHER dirs must be removed with that dir.
    link_dir = getattr(args, "dir", None)
    try:
        cmd_link(argparse.Namespace(remove=True, dir=link_dir))
    except SystemExit as exc:
        print(f"• Launcher not removed: {exc}", file=sys.stderr)
    if link_dir is None:
        print("• If you ran `ambient-codex link --dir <other>`, remove that one "
              "with `ambient-codex uninstall --dir <other>`.")

    # 3. State dir — ONLY with --purge, and ONLY if it is truly ours.
    if purge:
        root = os.path.realpath(STATE_DIR)
        if foreign_root(root) is not None:
            print(f"• Refusing to delete {root} — it is inside another install's tree.",
                  file=sys.stderr)
        elif os.path.isdir(root):
            import shutil
            errors = []
            shutil.rmtree(root, onerror=lambda fn, path, exc: errors.append(path))
            if not os.path.exists(root) and not errors:
                print(f"• Deleted all state: {root}")
            else:
                print(f"• Could not fully delete {root} "
                      f"({len(errors)} item(s) left) — remove it manually.",
                      file=sys.stderr)
        else:
            print(f"• No state dir to delete ({root}).")
    else:
        print(f"• Kept your settings and usage history in {STATE_DIR} "
              "(run with --purge to delete them).")

    # 4. The plugin itself is Codex's to remove.
    print("\nTo remove the plugin from Codex, run:")
    print("  codex plugin remove ambient-codex@ambient-codex")
    print("Git audit hooks, if you installed any, stay until you run "
          f"`{LAUNCHER_NAME} audit --uninstall-hook <hook>` in each repo.")


